# RAGrig Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run ./scripts/setup.sh — it copies .env.example → .env automatically.

# ── Local paths (required) ────────────────────────────────────────────────────
# Directories on the edge device (or host) where models, collections, and
# datasets are stored. These must be pre-provisioned; nothing is downloaded
# at runtime.

LOCAL_MODELS_DIR=/path/to/models
LOCAL_COLLECTIONS_DIR=/path/to/collections
LOCAL_DATASETS_DIR=/path/to/datasets

# ── Worker ────────────────────────────────────────────────────────────────────
# URL the orchestrator uses to reach the worker API.
WORKER_URL=http://localhost:8000

# ── Observability — Langfuse (default) ───────────────────────────────────────
# Self-hosted Langfuse instance. Use LANGFUSE_BASE_URL for local deployments;
# use https://cloud.langfuse.com for the managed cloud.
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-your-public-key
LANGFUSE_SECRET_KEY=sk-your-secret-key

# ── Observability — Weights & Biases / Weave (alternative, commented out) ────
# Uncomment to route traces to W&B Weave instead of (or in addition to) Langfuse.
# WANDB_API_KEY=your-wandb-api-key
# WANDB_BASE_URL=https://api.wandb.ai
# WANDB_ENTITY="my_team"
# WANDB_PROJECT="my_project"

# ── Observability — Generic OTEL (alternative, commented out) ─────────────────
# Uncomment to route traces to any OTLP-compatible backend.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Optional secrets ──────────────────────────────────────────────────────────
# HuggingFace token — only needed for gated datasets/models.
# HF_TOKEN=hf_your_token

# API key for remote LLM generation (e.g. Mistral API).
# LLM_API_KEY=your-llm-api-key

